{
  "name": "@stacksjs/tlsx",
  "type": "module",
  "sideEffects": false,
  "version": "0.13.11",
  "description": "A TLS/HTTPS library with automation.",
  "author": "Chris Breuer <chris@stacksjs.org>",
  "license": "MIT",
  "homepage": "https://github.com/stacksjs/tlsx#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/stacksjs/tlsx.git"
  },
  "bugs": {
    "url": "https://github.com/stacksjs/tlsx/issues"
  },
  "keywords": [
    "tls",
    "https",
    "ssl",
    "security",
    "https",
    "cryptography",
    "x509",
    "keys",
    "certificates",
    "rootca",
    "ca-bundle",
    "development",
    "environment",
    "bun",
    "stacks",
    "typescript",
    "javascript"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "bun": "./dist/src/index.js",
      "import": "./dist/src/index.js"
    }
  },
  "module": "./dist/src/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "tlsx": "./dist/bin/cli.js"
  },
  "files": [
    "README.md",
    "dist"
  ],
  "scripts": {
    "lint": "bunx --bun pickier .",
    "lint:fix": "bunx --bun pickier . --fix",
    "fresh": "bunx rimraf node_modules/ bun.lock && bun i",
    "prepublishOnly": "bun --bun run build",
    "test": "bun test",
    "typecheck": "bun --bun tsc --noEmit"
  },
  "devDependencies": {
    "bunfig": "^0.15.6",
    "typescript": "^7.0.2"
  },
  "simple-git-hooks": {
    "pre-commit": "bun lint-staged"
  },
  "lint-staged": {
    "*.{js,ts}": "bunx pickier . --fix"
  },
  "dependencies": {
    "@stacksjs/clapp": "^0.2.0"
  }
}
